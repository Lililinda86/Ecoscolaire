rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // UTILS : FONCTIONS DE SÉCURITÉ
    // ==========================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      // Les données de l'utilisateur qui fait la requête
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getRole() {
      return getUserData().role;
    }

    function getUserSchoolId() {
      return getUserData().schoolId;
    }

    function isActive() {
      let data = getUserData();
      return data.active == true || data.isActive == true;
    }

    function isUpdatingSaasFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'subscriptionPlan', 
        'subscriptionStatus', 
        'subscriptionStartDate', 
        'subscriptionEndDate', 
        'subscriptionRenewalDate', 
        'nextPaymentDate', 
        'isInternalSchool', 
        'studentLimit', 
        'studentsCount',
        'studentCount',
        'pilot',
        'billingStatus', 
        'billingCycle', 
        'trialEndsAt'
      ]);
    }

    function isUpdatingSensitiveUserFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'role',
        'schoolId',
        'schoolIds',
        'active',
        'status',
        'permissions',
        'studentIds'
      ]);
    }

    function isPromotingToSuperAdmin() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) 
             && request.resource.data.role == 'superAdmin';
    }

    function isChangingSchoolId() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(['schoolId', 'schoolIds']);
    }

    // --- Rôles ---
    function isSuperAdmin() {
      return getRole() == 'superAdmin';
    }
    function isOwner() {
      return getRole() == 'owner';
    }
    function isDirector() {
      return getRole() == 'director';
    }
    function isSecretary() {
      return getRole() == 'secretary';
    }
    function isAccountant() {
      return getRole() == 'accountant';
    }
    function isTeacher() {
      return getRole() == 'teacher';
    }
    function isDriver() {
      return getRole() == 'driver';
    }
    function isParent() {
      return getRole() == 'parent';
    }
    function isStudent() {
      return getRole() == 'student';
    }

    // --- Droits Composés ---
    function isAdminOrOwner() {
      return isSuperAdmin() || isOwner();
    }
    function hasSchoolAccess(schoolId) {
      return isSuperAdmin() || getUserSchoolId() == schoolId;
    }
    function canManageSchool(schoolId) {
      return isSuperAdmin() || (isOwner() && getUserSchoolId() == schoolId);
    }
    function canManagePedagogy(schoolId) {
      return hasSchoolAccess(schoolId) && (isAdminOrOwner() || isDirector() || isSecretary());
    }

    function canCreateStudentWithinLimits(schoolId) {
      let school = get(/databases/$(database)/documents/schools/$(schoolId)).data;
      let isInternal = school.get('isInternalSchool', false) == true;
      let plan = school.get('subscriptionPlan', 'starter');
      let count = school.get('studentsCount', 0);
      
      return isInternal 
          || plan == 'premium'
          || (plan == 'pilot' && count < 1000)
          || (plan == 'standard' && count < 1000)
          || (plan == 'starter' && count < 200);
    }

    // ==========================================
    // RULES PER COLLECTION
    // ==========================================

    // Par défaut, tout refuser.
    match /{document=**} {
      allow read, write: if false;
    }

    // --- USERS ---
    match /users/{userId} {
      // Un utilisateur peut lire son propre document.
      // Le superAdmin peut lire tous les utilisateurs.
      // L'owner, le directeur et la secrétaire peuvent lire les utilisateurs de leur école.
      allow get: if isAuthenticated() && request.auth.uid == userId;
      allow get: if isAuthenticated() && isActive() && (
        isSuperAdmin() ||
        ((isOwner() || isDirector() || isSecretary()) && hasSchoolAccess(resource.data.schoolId))
      );
      allow list: if isAuthenticated() && isActive() && (
        isSuperAdmin() ||
        ((isOwner() || isDirector() || isSecretary()) && hasSchoolAccess(resource.data.schoolId))
      );

      // Autorise superAdmin/owner à créer, OU le premier superAdmin via email, OU Auto-inscription Parent via Invitation
      allow create: if isAuthenticated() && (
        isSuperAdmin() || isOwner() || 
        (request.auth.token.email in ['kyrialove@gmail.com', 'superadmin.test@ecoscolaire.com'] && request.auth.uid == userId) ||
        (
          request.auth.uid == userId &&
          request.resource.data.role == 'parent' &&
          request.resource.data.keys().hasAll(['inviteId', 'studentIds']) &&
          get(/databases/$(database)/documents/parent_invitations/$(request.resource.data.inviteId)).data.status == 'pending' &&
          get(/databases/$(database)/documents/parent_invitations/$(request.resource.data.inviteId)).data.parentEmailLower == request.auth.token.email &&
          get(/databases/$(database)/documents/parent_invitations/$(request.resource.data.inviteId)).data.schoolId == request.resource.data.schoolId &&
          request.resource.data.studentIds == get(/databases/$(database)/documents/parent_invitations/$(request.resource.data.inviteId)).data.studentIds &&
          !request.resource.data.keys().hasAny(['isInternalSchool', 'subscriptionPlan', 'studentLimit', 'pilot', 'permissions', 'claims', 'customClaims'])
        )
      );
      allow update: if isAuthenticated() && isActive() && (
        isSuperAdmin() || 
        (
          (request.auth.uid == userId || (isOwner() && hasSchoolAccess(resource.data.schoolId))) &&
          !isUpdatingSensitiveUserFields()
        )
      );
      allow delete: if isAuthenticated() && isActive() && canManageSchool(resource.data.schoolId);
    }

    // --- SCHOOLS ---
    match /schools/{schoolId} {
      allow read: if isAuthenticated() && isActive() && hasSchoolAccess(schoolId);
      
      // Seul le superAdmin peut créer ou supprimer des écoles
      allow create, delete: if isAuthenticated() && isSuperAdmin();
      // Le propriétaire peut modifier son école (mais pas l'abonnement SaaS)
      allow update: if isAuthenticated() && isActive() && (
        isSuperAdmin() || 
        (canManageSchool(schoolId) && !isUpdatingSaasFields())
      );

      match /secrets/{secretId} {
        allow read: if false;
        allow create, update: if isAuthenticated() && isActive() && (isSuperAdmin() || isOwner()) && hasSchoolAccess(schoolId);
        allow delete: if isAuthenticated() && isActive() && isSuperAdmin();
      }
    }

    // --- PARENT INVITATIONS ---
    match /parent_invitations/{inviteId} {
      allow read: if isAuthenticated() && isActive() && (isAdminOrOwner() || isDirector() || isSecretary()) && hasSchoolAccess(resource.data.schoolId);
      allow get: if resource.data.status == 'pending' && resource.data.expiresAt > request.time; // Not fully possible to compare string ISO with toMillis simply in rules if it's stored as string. Wait, ISO strings can be compared directly in lexicographical order!
      // Better yet, just check pending. The client checks expiration, or we can check string:
      // allow get: if resource.data.status == 'pending'; (the UI will check expiration)
      
      allow create: if isAuthenticated() && isActive() && (isAdminOrOwner() || isDirector() || isSecretary()) && hasSchoolAccess(request.resource.data.schoolId);
      
      allow update: if isAuthenticated() && isActive() && (isAdminOrOwner() || isDirector() || isSecretary()) && hasSchoolAccess(resource.data.schoolId);
      
      allow update: if isAuthenticated() && 
                    (request.auth.token.email == resource.data.parentEmailLower || request.auth.token.email == resource.data.parentEmail) &&
                    resource.data.status == 'pending' &&
                    request.resource.data.status == 'used' &&
                    request.resource.data.usedBy == request.auth.uid;
    }

    // --- STUDENTS & PARENTS ---
    match /students/{studentId} {
      allow read: if isAuthenticated() && isActive() && (
        isSuperAdmin() || 
        ((isOwner() || isDirector() || isSecretary() || isTeacher() || isAccountant()) && hasSchoolAccess(resource.data.schoolId)) ||
        (isParent() && hasSchoolAccess(resource.data.schoolId) && (studentId in getUserData().studentIds || request.auth.token.email in resource.data.parentEmails))
      );
      // Création par Owner, Director, Secretary AVEC limite
      allow create: if isAuthenticated() && isActive() && canManagePedagogy(request.resource.data.schoolId) && canCreateStudentWithinLimits(request.resource.data.schoolId);
      // Update
      allow update: if isAuthenticated() && isActive() && canManagePedagogy(request.resource.data.schoolId);
      // Delete (Demande validation dans le client, mais ici la vraie suppression requiert owner)
      allow delete: if isAuthenticated() && isActive() && canManageSchool(resource.data.schoolId);
    }

    match /parents/{parentId} {
      // Les parents sont migrés dans `users`, mais si on garde une collection séparée pour l'historique
      allow read, write: if isAuthenticated() && isActive() && canManagePedagogy(resource.data.schoolId);
    }

    // --- CLASSES & SUBJECTS ---
    match /classes/{classId} {
      allow read: if isAuthenticated() && isActive() && hasSchoolAccess(resource.data.schoolId);
      allow write: if isAuthenticated() && isActive() && canManagePedagogy(request.resource.data.schoolId);
    }
    match /subjects/{subjectId} {
      allow read: if isAuthenticated() && isActive() && hasSchoolAccess(resource.data.schoolId);
      allow write: if isAuthenticated() && isActive() && canManagePedagogy(request.resource.data.schoolId);
    }

    // --- STUDENT IMPORT JOBS ---
    match /student_import_jobs/{jobId} {
      allow read: if isAuthenticated() && isActive() && (isSuperAdmin() || hasSchoolAccess(resource.data.schoolId));
      allow create: if isAuthenticated() && isActive() && canManagePedagogy(request.resource.data.schoolId)
                    && request.resource.data.status == 'PENDING'
                    && request.resource.data.processedCount == 0
                    && request.resource.data.createdCount == 0
                    && request.resource.data.updatedCount == 0
                    && request.resource.data.skippedCount == 0
                    && request.resource.data.failedCount == 0
                    && request.resource.data.storagePath.matches('^import_jobs_data/' + request.resource.data.schoolId + '/.*');
      allow update, delete: if false; // Only Cloud Functions (Admin SDK) can update/delete
    }

    // --- GRADES & ATTENDANCE ---
    match /audit_logs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isSuperAdmin() || ((isOwner() || isDirector()) && resource.data.schoolId == getUserSchoolId());
      allow update, delete: if false; // Immuable
    }

    match /grades/{gradeId} {
      allow read: if isAuthenticated() && isActive() && (
        isSuperAdmin() || 
        ((isOwner() || isDirector() || isSecretary() || isTeacher()) && hasSchoolAccess(resource.data.schoolId)) ||
        (isParent() && hasSchoolAccess(resource.data.schoolId)) // La logique "uniquement si payé" est gérée par le client, on peut difficilement la faire en rules sans check croisé de /payments/
      );
      allow create, update: if isAuthenticated() && isActive() && (isAdminOrOwner() || isDirector() || isTeacher()) && hasSchoolAccess(request.resource.data.schoolId);
      allow delete: if isAuthenticated() && isActive() && canManagePedagogy(resource.data.schoolId);
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated() && isActive() && hasSchoolAccess(resource.data.schoolId);
      allow write: if isAuthenticated() && isActive() && (isAdminOrOwner() || isDirector() || isSecretary() || isTeacher()) && hasSchoolAccess(request.resource.data.schoolId);
    }
    match /staff/{staffId} {
      allow read: if isAuthenticated() && isActive() && hasSchoolAccess(resource.data.schoolId);
      allow write: if isAuthenticated() && isActive() && canManagePedagogy(request.resource.data.schoolId);
    }
    match /staffAttendance/{attendanceId} {
      allow read: if isAuthenticated() && isActive() && canManagePedagogy(resource.data.schoolId);
      allow write: if isAuthenticated() && isActive() && canManagePedagogy(request.resource.data.schoolId);
    }

    // --- FINANCE (PAYMENTS & EXPENSES) ---
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && isActive() && (
        resource.data.userId == request.auth.uid ||
        isSuperAdmin() ||
        ((isOwner() || isDirector() || isAccountant()) && hasSchoolAccess(resource.data.schoolId))
      );
      allow create, update, delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && isActive() && (
        isSuperAdmin() || 
        ((isOwner() || isDirector() || isSecretary() || isAccountant()) && hasSchoolAccess(resource.data.schoolId)) ||
        (isParent() && hasSchoolAccess(resource.data.schoolId))
      );
      // Seuls le comptable, le propriétaire et le superAdmin gèrent l'argent.
      allow write: if isAuthenticated() && isActive() && (isAdminOrOwner() || isAccountant()) && hasSchoolAccess(request.resource.data.schoolId);
    }
    match /receipts/{receiptId} {
      allow read: if isAuthenticated() && isActive() && (
        isSuperAdmin() || 
        ((isOwner() || isDirector() || isSecretary() || isAccountant()) && hasSchoolAccess(resource.data.schoolId)) ||
        (isParent() && hasSchoolAccess(resource.data.schoolId))
      );
      // Création gérée uniquement par le backend (Cloud Functions onPaymentCreated)
      allow write: if false;
    }
    match /expenses/{expenseId} {
      allow read: if isAuthenticated() && isActive() && (isAdminOrOwner() || isAccountant()) && hasSchoolAccess(resource.data.schoolId);
      allow write: if isAuthenticated() && isActive() && (isAdminOrOwner() || isAccountant()) && hasSchoolAccess(request.resource.data.schoolId);
    }

    // --- INVENTORY ---
    match /inventory/{itemId} {
      allow read: if isAuthenticated() && isActive() && hasSchoolAccess(resource.data.schoolId);
      allow write: if isAuthenticated() && isActive() && (isAdminOrOwner() || isSecretary() || isAccountant()) && hasSchoolAccess(request.resource.data.schoolId);
    }
    match /inventoryTransactions/{txId} {
      allow read: if isAuthenticated() && isActive() && (isAdminOrOwner() || isSecretary() || isAccountant()) && hasSchoolAccess(resource.data.schoolId);
      allow write: if isAuthenticated() && isActive() && (isAdminOrOwner() || isSecretary() || isAccountant()) && hasSchoolAccess(request.resource.data.schoolId);
    }

    // --- TRANSPORT ---
    match /buses/{busId} {
      // Driver voit le transport
      allow read: if isAuthenticated() && isActive() && (
        hasSchoolAccess(resource.data.schoolId) && (isAdminOrOwner() || isSecretary() || isAccountant() || isDriver())
      );
      allow write: if isAuthenticated() && isActive() && (isAdminOrOwner() || isSecretary() || isDriver()) && hasSchoolAccess(request.resource.data.schoolId);
    }
    match /busRoutes/{routeId} {
      allow read: if isAuthenticated() && isActive() && (isAdminOrOwner() || isSecretary() || isDriver()) && hasSchoolAccess(resource.data.schoolId);
      allow write: if isAuthenticated() && isActive() && (isAdminOrOwner() || isSecretary() || isDriver()) && hasSchoolAccess(request.resource.data.schoolId);
    }
    match /fuelExpenses/{expId} {
      allow read: if isAuthenticated() && isActive() && (isAdminOrOwner() || isAccountant() || isDriver()) && hasSchoolAccess(resource.data.schoolId);
      allow write: if isAuthenticated() && isActive() && (isAdminOrOwner() || isAccountant() || isDriver()) && hasSchoolAccess(request.resource.data.schoolId);
    }
    match /maintenances/{mId} {
      allow read: if isAuthenticated() && isActive() && (isAdminOrOwner() || isAccountant() || isDriver()) && hasSchoolAccess(resource.data.schoolId);
      allow write: if isAuthenticated() && isActive() && (isAdminOrOwner() || isAccountant() || isDriver()) && hasSchoolAccess(request.resource.data.schoolId);
    }
    match /breakdowns/{bId} {
      allow read: if isAuthenticated() && isActive() && (isAdminOrOwner() || isDriver()) && hasSchoolAccess(resource.data.schoolId);
      allow write: if isAuthenticated() && isActive() && (isAdminOrOwner() || isDriver()) && hasSchoolAccess(request.resource.data.schoolId);
    }

    // --- VALIDATION REQUESTS ---
    match /validation_requests/{reqId} {
      // N'importe quel membre du staff peut créer une requête
      allow create: if isAuthenticated() && isActive() && hasSchoolAccess(request.resource.data.schoolId);
      // Tout le staff peut lire les requêtes de son école
      allow read: if isAuthenticated() && isActive() && hasSchoolAccess(resource.data.schoolId);
      // Seuls les approbateurs peuvent modifier/résoudre
      allow update, delete: if isAuthenticated() && isActive() && (isAdminOrOwner() || isDirector()) && hasSchoolAccess(resource.data.schoolId);
    }

    // --- NOTIFICATIONS ---
    match /notifications/{notifId} {
      // Tout utilisateur connecté peut recevoir/créer des notifications dans son école
      allow read, update, delete: if isAuthenticated() && isActive() && hasSchoolAccess(resource.data.schoolId);
      allow create: if isAuthenticated() && isActive() && hasSchoolAccess(request.resource.data.schoolId);
    }
  }
}
